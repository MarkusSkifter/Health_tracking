# Copy to .env and fill in. NEVER commit .env.

# --- intervals.icu (SPEC Section 4) ---
# Personal API key, used via HTTP Basic auth (username "API_KEY", password = this key).
INTERVALS_API_KEY=
# Your intervals.icu athlete id, e.g. i123456
INTERVALS_ATHLETE_ID=

# --- Anthropic / Claude (SPEC Section 7) ---
# Daily summary uses model claude-sonnet-4-6.
ANTHROPIC_API_KEY=

# --- Postgres (SPEC Section 5) ---
# Matches docker-compose.yml for local dev (`docker compose up -d`).
DATABASE_URL=postgres://postgres:postgres@localhost:5432/health_tracking

# --- API server ---
PORT=3001

# --- COROS API ---
COROS_CLIENT_ID=
COROS_CLIENT_SECRET=

# --- Frontend (web) ---
# Base URL of the API the web app calls. Defaults to http://localhost:3001 in dev.
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
